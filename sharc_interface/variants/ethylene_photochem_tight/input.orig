geomfile     "geom"
veloc        external
velocfile    "veloc"

nstates      2
actstates    2
state        2 mch
coeff        auto
rngseed      101

ezero        -78.0566
tmax         60.0
stepsize     0.5
nsubsteps    5

surf         sharc
coupling     nacdr
nogradcorrect
ekincorrect  parallel_vel
decoherence_scheme edc
decoherence_param 0.1
grad_select
nac_select
eselect      0.5
select_directly

nospinorbit
output_format ascii
